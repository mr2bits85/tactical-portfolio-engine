# Example environment variables for local development
# Copy this file to .env and fill in the values as needed

# For Streamlit (optional, defaults are set in Dockerfile and docker-compose)
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=0.0.0.0

# For local development user (used by auth.py when IAP header is not present)
DEV_USER_EMAIL=dev@example.com

# Database connection (used by services when they have a database session)
# Format: postgresql://username:password@host:port/database
# Example for Cloud SQL Proxy local testing:
# TACTICAL_DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/tactical_portfolio_db
TACTICAL_DATABASE_URL=

# Google Cloud Project ID (needed for Secret Manager if not running in Cloud Run)
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id

# Example secrets (if you want to test Secret Manager locally or use fallback)
# These are used by secret_manager.py: it first checks environment variables, then Secret Manager
# So for local testing without Secret Manager, set these environment variables to the secret values.

# Example: if you have a secret named "API_KEY" in Secret Manager, set:
# API_KEY=your_api_key_here

# Add other secrets as needed for your application
# For example, from the Project_Ledger.md, we might have:
# - API keys for market data providers (though yfinance is free)
# - Other service keys

# Leave empty or comment out if not needed